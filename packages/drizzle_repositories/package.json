{
  "name": "@wovalle/drizzle-repositories",
  "version": "0.0.1",
  "description": "Generic repository layer for Drizzle ORM with audit logging (Postgres + D1/SQLite)",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": "./dist/src/index.js",
    "./sqlite": "./dist/src/sqlite/index.js",
    "./postgres": "./dist/src/postgres/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "drizzle",
    "drizzle-orm",
    "repository",
    "postgres",
    "d1",
    "sqlite",
    "audit"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wovalle/willy.im",
    "directory": "packages/drizzle_repositories"
  },
  "peerDependencies": {
    "drizzle-orm": "^1.0.0-beta.15-859cf75",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "drizzle-orm": "^1.0.0-beta.15-859cf75",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
