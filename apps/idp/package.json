{
  "name": "idp",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "wrangler types",
    "deploy": "npm run build && wrangler deploy",
    "dev": "react-router dev",
    "postinstall": "npm run cf-typegen",
    "preview": "npm run build && vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "npm run cf-typegen && npx react-router typegen && npx tsc -b",
    "db:studio": "LOCAL_DB_PATH=$(find .wrangler/state/v3/d1/miniflare-D1DatabaseObject -type f -name '*.sqlite' -print -quit) drizzle-kit studio",
    "db:generate": "dotenv -- drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply --local db",
    "db:migrate-prod": "wrangler d1 migrations apply --remote db",
    "auth:db:generate": "ln -sf \"$(cd ../.. && pwd)/apps/idp/node_modules/drizzle-orm\" ../../node_modules/drizzle-orm; better-auth generate --config scripts/auth.gen.ts --output app/db/auth-schema.ts --yes; rm -f ../../node_modules/drizzle-orm"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@better-auth/oauth-provider": "^1.6.15",
    "@better-auth/passkey": "^1.6.15",
    "@fontsource-variable/geist": "^5.2.9",
    "better-auth": "^1.6.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.6",
    "isbot": "^5.1.31",
    "lucide-react": "^1.17.0",
    "react": "^19.1.1",
    "react-dom": "^19.2.0",
    "react-router": "^7.9.2",
    "resend": "^6.12.4",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tiny-invariant": "^1.3.3",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@cloudflare/vite-plugin": "^1.30.3",
    "@react-router/dev": "^7.9.2",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "dotenv-cli": "^10.0.0",
    "drizzle-kit": "^0.31.5",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "wrangler": "^4.40.3"
  }
}
